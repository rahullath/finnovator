# Copy this to .env and fill in your values

# Anthropic — https://console.anthropic.com (needed for live claim extraction)
ANTHROPIC_API_KEY=sk-ant-...

# Financial Modeling Prep — https://financialmodelingprep.com/developer/docs (free tier, 250 req/day)
FMP_API_KEY=...

# Supabase — https://supabase.com (optional, for persistence/multi-user demo)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Set to "true" to always use pre-baked CSV data (recommended for demo day to avoid API flakiness)
USE_STATIC_DATA=true
